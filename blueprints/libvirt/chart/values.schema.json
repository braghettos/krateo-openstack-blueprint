{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "title": "OpenStack libvirt",
  "description": "Configuration for the libvirt/QEMU hypervisor agent (OpenStack-Helm libvirt, release 2025.1). Only the fields here are settable on a Composition; everything else uses the chart defaults in values.yaml. Deploy all the OpenStack component blueprints into one namespace to form a complete install.",
  "properties": {
    "images": {
      "type": "object",
      "title": "Images",
      "properties": {
        "pull_policy": {
          "type": "string",
          "title": "Image pull policy",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "default": "IfNotPresent"
        }
      }
    },
    "conf": {
      "type": "object",
      "title": "Config",
      "properties": {
        "libvirt": {
          "type": "object",
          "properties": {
            "virt_type": {
              "type": "string",
              "title": "Virtualization type",
              "enum": [
                "qemu",
                "kvm"
              ],
              "default": "qemu"
            }
          }
        }
      }
    }
  }
}