{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "title": "OpenStack designate",
  "description": "Configuration for the OpenStack designate service (OpenStack-Helm designate, release 2025.1). Only the fields here are settable on a Composition; everything else uses the chart defaults in values.yaml. Deploy all the OpenStack component blueprints into one namespace to form a complete install.",
  "properties": {
    "images": {
      "type": "object",
      "title": "Images",
      "properties": {
        "pull_policy": {
          "type": "string",
          "title": "Image pull policy",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "default": "IfNotPresent"
        }
      }
    },
    "pod": {
      "type": "object",
      "title": "Pods",
      "properties": {
        "replicas": {
          "type": "object",
          "title": "Replicas",
          "properties": {
            "api": {
              "type": "integer",
              "title": "Designate api replicas",
              "minimum": 1,
              "maximum": 5,
              "default": 1
            },
            "central": {
              "type": "integer",
              "title": "Designate central replicas",
              "minimum": 1,
              "maximum": 5,
              "default": 1
            },
            "mdns": {
              "type": "integer",
              "title": "Designate mdns replicas",
              "minimum": 1,
              "maximum": 5,
              "default": 1
            },
            "producer": {
              "type": "integer",
              "title": "Designate producer replicas",
              "minimum": 1,
              "maximum": 5,
              "default": 1
            },
            "sink": {
              "type": "integer",
              "title": "Designate sink replicas",
              "minimum": 1,
              "maximum": 5,
              "default": 1
            },
            "worker": {
              "type": "integer",
              "title": "Designate worker replicas",
              "minimum": 1,
              "maximum": 5,
              "default": 1
            }
          }
        }
      }
    }
  }
}