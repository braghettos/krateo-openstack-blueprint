{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "title": "OpenStack aodh",
  "description": "Configuration for the OpenStack aodh service (OpenStack-Helm aodh, release 2025.1). Only the fields here are settable on a Composition; everything else uses the chart defaults in values.yaml. Deploy all the OpenStack component blueprints into one namespace to form a complete install.",
  "properties": {
    "images": {
      "type": "object",
      "title": "Images",
      "properties": {
        "pull_policy": {
          "type": "string",
          "title": "Image pull policy",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "default": "IfNotPresent"
        }
      }
    },
    "pod": {
      "type": "object",
      "title": "Pods",
      "properties": {
        "replicas": {
          "type": "object",
          "title": "Replicas",
          "properties": {
            "api": {
              "type": "integer",
              "title": "Aodh api replicas",
              "minimum": 1,
              "maximum": 5,
              "default": 1
            },
            "evaluator": {
              "type": "integer",
              "title": "Aodh evaluator replicas",
              "minimum": 1,
              "maximum": 5,
              "default": 1
            },
            "listener": {
              "type": "integer",
              "title": "Aodh listener replicas",
              "minimum": 1,
              "maximum": 5,
              "default": 1
            },
            "notifier": {
              "type": "integer",
              "title": "Aodh notifier replicas",
              "minimum": 1,
              "maximum": 5,
              "default": 1
            }
          }
        }
      }
    }
  }
}