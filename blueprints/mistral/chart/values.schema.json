{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "title": "OpenStack mistral",
  "description": "Configuration for the OpenStack mistral service (OpenStack-Helm mistral, release 2025.1). Only the fields here are settable on a Composition; everything else uses the chart defaults in values.yaml. Deploy all the OpenStack component blueprints into one namespace to form a complete install.",
  "properties": {
    "images": {
      "type": "object",
      "title": "Images",
      "properties": {
        "pull_policy": {
          "type": "string",
          "title": "Image pull policy",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "default": "IfNotPresent"
        }
      }
    },
    "pod": {
      "type": "object",
      "title": "Pods",
      "properties": {
        "replicas": {
          "type": "object",
          "title": "Replicas",
          "properties": {
            "api": {
              "type": "integer",
              "title": "Mistral api replicas",
              "minimum": 1,
              "maximum": 5,
              "default": 1
            },
            "engine": {
              "type": "integer",
              "title": "Mistral engine replicas",
              "minimum": 1,
              "maximum": 5,
              "default": 1
            },
            "event_engine": {
              "type": "integer",
              "title": "Mistral event_engine replicas",
              "minimum": 1,
              "maximum": 5,
              "default": 1
            },
            "executor": {
              "type": "integer",
              "title": "Mistral executor replicas",
              "minimum": 1,
              "maximum": 5,
              "default": 1
            }
          }
        }
      }
    }
  }
}