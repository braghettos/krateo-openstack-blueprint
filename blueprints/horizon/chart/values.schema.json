{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "title": "OpenStack horizon",
  "description": "Configuration for the Horizon dashboard (OpenStack-Helm horizon, release 2025.1). Only the fields here are settable on a Composition; everything else uses the chart defaults in values.yaml. Deploy all the OpenStack component blueprints into one namespace to form a complete install.",
  "properties": {
    "images": {
      "type": "object",
      "title": "Images",
      "properties": {
        "pull_policy": {
          "type": "string",
          "title": "Image pull policy",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "default": "IfNotPresent"
        }
      }
    },
    "pod": {
      "type": "object",
      "title": "Pods",
      "properties": {
        "replicas": {
          "type": "object",
          "title": "Replicas",
          "properties": {
            "server": {
              "type": "integer",
              "title": "Horizon replicas",
              "minimum": 1,
              "maximum": 5,
              "default": 1
            }
          }
        }
      }
    },
    "network": {
      "type": "object",
      "title": "Network",
      "properties": {
        "dashboard": {
          "type": "object",
          "title": "Dashboard",
          "properties": {
            "service": {
              "type": "object",
              "title": "Service",
              "properties": {
                "type": {
                  "type": "string",
                  "title": "Service type",
                  "description": "How to expose Horizon. NodePort (default; uses the NodePort below), LoadBalancer (external L4 LB + public IP on GKE/EKS/AKS), or ClusterIP (in-cluster only).",
                  "enum": [
                    "NodePort",
                    "LoadBalancer",
                    "ClusterIP"
                  ],
                  "default": "NodePort"
                },
                "annotations": {
                  "type": "object",
                  "title": "Service annotations",
                  "description": "Annotations for the Service, e.g. cloud LB controls (internal LB, static IP, ...).",
                  "additionalProperties": { "type": "string" }
                }
              }
            }
          }
        },
        "node_port": {
          "type": "object",
          "title": "NodePort",
          "properties": {
            "enabled": {
              "type": "boolean",
              "title": "Expose on NodePort",
              "default": true
            },
            "port": {
              "type": "integer",
              "title": "Dashboard NodePort",
              "minimum": 30000,
              "maximum": 32767,
              "default": 31000
            }
          }
        }
      }
    }
  }
}